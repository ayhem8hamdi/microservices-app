// apps/notifications/prisma/schema.prisma
generator client {
provider = "prisma-client-js"
output = "../../../node_modules/.prisma/notifications-client"
}
datasource db {
provider = "postgresql"
url = env("NOTIFICATIONS_DATABASE_URL")
}
// Notifications logs every notification it sends
// Useful for debugging, deduplication, and audit trails
model Notification {
id Int @id @default(autoincrement())
userId Int
type NotificationType
payload Json // Flexible — stores event data as JSON
sentAt DateTime @default(now())
status NotifStatus @default(SENT)
}
enum NotificationType {
ORDER_CONFIRMATION
PASSWORD_RESET
WELCOME
}
enum NotifStatus {
SENT
FAILED
PENDING
}
